@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix void: <http://rdfs.org/ns/void#> .

<http://www.opengis.net/def/crs/EPSG/0/6075_area_of_use> a ns1:AreaOfUse,
        <http://www.w3.org/ns/ldp#Resource>,
        <https://www.iana.org/assignments/media-types/text/turtle#Resource> ;
    rdfs:label "Arctic - between 84°30'N and 79°30'N, approximately 33°E to approximately 73°E. May be extended westwards or eastwards within the latitude limits."@en ;
    void:inDataset <http://www.opengis.net/dataset> ;
    ns1:extent "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON ((73.01000000000001 79.5, 73.01000000000001 84.51000000000001, 33 84.51000000000001, 33 79.5, 73.01000000000001 79.5))"^^geo:wktLiteral .

