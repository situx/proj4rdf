@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix void: <http://rdfs.org/ns/void#> .

<http://www.opengis.net/def/crs/EPSG/0/5928_area_of_use> a ns1:AreaOfUse,
        <http://www.w3.org/ns/ldp#Resource>,
        <https://www.iana.org/assignments/media-types/text/turtle#Resource> ;
    rdfs:label "Arctic - 79°N to 67°N, approximately 12°W to approximately 78°E. May be extended westwards or eastwards within the latitude limits."@en ;
    void:inDataset <http://www.opengis.net/dataset> ;
    ns1:extent "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON ((78.01000000000001 67, 78.01000000000001 79.01000000000001, -12 79.01000000000001, -12 67, 78.01000000000001 67))"^^geo:wktLiteral .

