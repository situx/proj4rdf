@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/def/crs/EPSG/0/9354_area_of_use> a ns1:AreaOfUse ;
    rdfs:label "Southern hemisphere - south of 50°S onshore and offshore, including Antarctica."@en ;
    ns1:extent "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON ((180 -90, 180 -50, -180 -50, -180 -90, 180 -90))"^^geo:wktLiteral .

