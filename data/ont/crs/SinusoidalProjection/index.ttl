@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SinusoidalProjection a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "sinusoidal projection"@en ;
    ns1:PROJidentifier "sinu" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:EquidistantProjection,
        ns1:PseudoCylindricalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/SinusoidalProjection.svg"^^xsd:anyURI .

