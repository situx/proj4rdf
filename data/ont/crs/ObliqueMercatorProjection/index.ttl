@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ObliqueMercatorProjection a owl:Class ;
    rdfs:label "oblique mercator projection"@en ;
    ns1:PROJidentifier "omerc" ;
    rdfs:subClassOf ns1:CylindricalProjection,
        ns1:MercatorProjection,
        ns1:ObliqueProjection .

