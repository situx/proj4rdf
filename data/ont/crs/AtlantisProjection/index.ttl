@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/AtlantisProjection> a owl:Class ;
    rdfs:label "atlantis projection"@en ;
    dc:creator "John Bartholomew" ;
    dc:date "1948"^^xsd:gYear ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/EqualAreaProjection>,
        <http://www.opengis.net/ont/crs/PseudoCylindricalProjection> ;
    foaf:image "https://situx.github.io/proj4rdf/projections/AtlantisProjection.svg"^^xsd:anyURI .

