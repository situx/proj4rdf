@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/AzimuthalProjection> a owl:Class ;
    rdfs:label "azimuthal projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/Projection> ;
    skos:definition "A projection with the property that directions from a central point are preserved"@en .

