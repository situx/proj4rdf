@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/ConformalProjection> a owl:Class ;
    rdfs:label "conformal projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/Projection> ;
    skos:definition "A projection in which every angle between two curves that crosss each other on a celestical boday is preserved in the image of the projection"@en .

