@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/ObliquePlateCarreeProjection> a owl:Class ;
    rdfs:label "Oblique Plate Carree Projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CylindricalProjection>,
        <http://www.opengis.net/ont/crs/EquidistantProjection> .

