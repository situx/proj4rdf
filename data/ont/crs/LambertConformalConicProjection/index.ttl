@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:LambertConformalConicProjection a owl:Class ;
    rdfs:label "lambert conformal conic projection"@en ;
    dc:creator "Johann Heinrich Lambert" ;
    dc:date "1772"^^xsd:gYear ;
    ns1:PROJidentifier "lcc" ;
    rdfs:subClassOf ns1:ConformalProjection,
        ns1:ConicalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/LambertConformalConicProjection.svg"^^xsd:anyURI .

