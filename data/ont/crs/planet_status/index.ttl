@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/planet_status> a owl:ObjectProperty ;
    rdfs:label "planet status"@en ;
    rdfs:domain <http://www.opengis.net/ont/crs/InterstellarBody> ;
    rdfs:range <http://www.opengis.net/ont/crs/PlanetStatus> ;
    skos:definition "The status of the discovery of the planet, e.g. confirmed, unsure etc."@en .

