@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BaconGlobularProjection a owl:Class ;
    rdfs:label "bacon globular projection"@en ;
    dc:creator "Roger Bacon" ;
    dc:date "1265" ;
    ns1:PROJidentifier "bacon" ;
    rdfs:subClassOf ns1:GlobularProjection .

