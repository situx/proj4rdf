@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/isbody/Elara> a ns1:Moon ;
    rdfs:label "Elara"@en ;
    ns1:planet_status ns1:Confirmed ;
    ns1:radius 4.3e+01 ;
    ns1:satelliteOf <http://www.opengis.net/ont/crs/isbody/Jupiter> .

