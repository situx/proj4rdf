@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/coordinateOperation> a owl:ObjectProperty ;
    rdfs:label "coordinate operation"@en ;
    rdfs:domain <http://www.opengis.net/ont/crs/CRS> ;
    rdfs:isDefinedBy <http://docs.opengeospatial.org/as/18-005r4/18-005r4.html> ;
    rdfs:range <http://www.opengis.net/ont/crs/CoordinateOperation> ;
    skos:definition "Associates a coordinate operation with a CRS"@en .

