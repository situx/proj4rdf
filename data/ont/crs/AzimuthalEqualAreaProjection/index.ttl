@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/AzimuthalEqualAreaProjection> a owl:Class ;
    rdfs:label "Azimuthal Equal-Area projection" ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/AzimuthalProjection>,
        <http://www.opengis.net/ont/crs/EqualAreaProjection> ;
    foaf:image "https://situx.github.io/proj4rdf/projections/AzimuthalEqualAreaProjection.svg"^^xsd:anyURI .

