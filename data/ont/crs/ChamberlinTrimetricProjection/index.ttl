@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ChamberlinTrimetricProjection a owl:Class ;
    rdfs:label "chamberlin trimetric projection"@en ;
    dc:creator "Wellman Chamberlin" ;
    dc:date "1946" ;
    ns1:PROJidentifier "chamb" ;
    rdfs:subClassOf ns1:CompromiseProjection .

