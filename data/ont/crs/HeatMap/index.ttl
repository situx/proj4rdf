@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/HeatMap> a owl:Class ;
    rdfs:label "heat map"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/ThematicMap> ;
    owl:disjointWith <http://www.opengis.net/ont/crs/ChloroplethMap> ;
    skos:definition "A data visualization technique that shows magnitude of a phenomenon as color in two dimensions."@en .

