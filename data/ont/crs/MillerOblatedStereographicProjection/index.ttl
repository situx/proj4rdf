@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MillerOblatedStereographicProjection a owl:Class ;
    rdfs:label "Miller oblated stereographic projection" ;
    ns1:PROJidentifier "mil_os" ;
    rdfs:subClassOf ns1:StereographicProjection .

