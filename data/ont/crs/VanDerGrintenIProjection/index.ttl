@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:VanDerGrintenIProjection a owl:Class ;
    rdfs:label "van der grinten I projection"@en ;
    ns1:PROJidentifier "vandg" ;
    rdfs:subClassOf ns1:CompromiseProjection,
        ns1:PolyconicProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/VanDerGrintenIProjection.svg"^^xsd:anyURI .

