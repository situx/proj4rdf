@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AmericanPolyconicProjection a owl:Class ;
    rdfs:label "american polyconic projection"@en ;
    dc:creator "Ferdinand Rudolph Hassler" ;
    dc:date "1820" ;
    ns1:PROJidentifier "poly" ;
    rdfs:subClassOf ns1:CompromiseProjection,
        ns1:PseudoConicalProjection .

