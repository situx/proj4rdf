@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:WagnerIIProjection a owl:Class ;
    rdfs:label "wagner II projection"@en ;
    dc:creator "Karlheinz Wagner" ;
    dc:date "1949"^^xsd:gYear ;
    ns1:PROJidentifier "wag2" ;
    rdfs:subClassOf ns1:PoleLineProjection,
        ns1:PseudoCylindricalProjection .

