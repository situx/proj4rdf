@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Reseau_de_Reference_des_Antilles_Francaises_1991> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Reseau de Reference des Antilles Francaises 1991"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/GRS1980>,
        <http://www.opengis.net/ont/crs/geod/WGS84> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:Geodesy,
        ns1:TopographicMap .

