@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Institut_Geographique_du_Congo_Belge_1955> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Institut Geographique du Congo Belge 1955"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/Clarke1880RGS> ;
