@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/datum/Mauritania_1999> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Mauritania 1999"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/Clarke1880RGS>,
        <http://www.opengis.net/ont/crs/geod/GRS1980> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
