@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Cyprus_Geodetic_Reference_System_1993> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Cyprus Geodetic Reference System 1993"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/WGS84> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:TopographicMap .

