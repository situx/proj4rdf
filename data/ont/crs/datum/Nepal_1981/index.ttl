@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Nepal_1981> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Nepal 1981"@en ;
    ns1:ellipse "Everest 1830 (1937 Adjustment)" ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:Geodesy,
        ns1:TopographicMap .

