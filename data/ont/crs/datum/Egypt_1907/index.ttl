@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Egypt_1907> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Egypt 1907"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/Helmert1906> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:Geodesy,
        ns1:TopographicMap .

