@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/datum/Australian_Terrestrial_Reference_Frame_2014> a ns1:DynamicGeodeticReferenceFrame ;
    rdfs:label "Datum: Australian Terrestrial Reference Frame 2014"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/GRS1980> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage "intelligent transport services"^^xsd:string,
        "location-based services"^^xsd:string,
        "navigation"^^xsd:string,
        "positioning"^^xsd:string .

