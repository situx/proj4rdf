@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Red_Geodesica_Para_Mineria_en_Chile> a ns1:DynamicGeodeticReferenceFrame ;
    rdfs:label "Datum: Red Geodesica Para Mineria en Chile"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/GRS1980> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:Geodesy,
        ns1:TopographicMap .

