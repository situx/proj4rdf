@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Taiwan_Datum_1967> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Taiwan Datum 1967"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/GRS67Modified> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:Geodesy,
        ns1:TopographicMap .

