@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/datum/Not_specified__based_on_Authalic_Sphere_> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Not specified (based on Authalic Sphere)"@en ;
    ns1:ellipse "Sphere" ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage "Not a valid datum"^^xsd:string .

