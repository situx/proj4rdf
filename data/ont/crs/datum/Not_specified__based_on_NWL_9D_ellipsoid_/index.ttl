@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/datum/Not_specified__based_on_NWL_9D_ellipsoid_> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Not specified (based on NWL 9D ellipsoid)"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/NWL9D> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage "Not a valid datum"^^xsd:string .

