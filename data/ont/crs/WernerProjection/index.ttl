@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/WernerProjection> a owl:Class ;
    rdfs:label "werner projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CordiformProjection>,
        <http://www.opengis.net/ont/crs/EqualAreaProjection>,
        <http://www.opengis.net/ont/crs/PseudoConicalProjection> .

