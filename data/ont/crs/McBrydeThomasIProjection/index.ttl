@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:McBrydeThomasIProjection a owl:Class ;
    rdfs:label "Mc Bryde-Thomas I projection" ;
    ns1:PROJidentifier "mbt_s" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection .

