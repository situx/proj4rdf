@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/PROJidentifier> a owl:AnnotationProperty ;
    rdfs:label "PROJ identifier"@en ;
    skos:definition "A short String identifier used to identify the projection in a PROJ string description"@en .

