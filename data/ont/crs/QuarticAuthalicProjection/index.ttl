@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:QuarticAuthalicProjection a owl:Class ;
    rdfs:label "quartic authalic projection"@en ;
    dc:creator "Karl Siemon" ;
    dc:date 1937 ;
    ns1:PROJidentifier "qua_aut" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection ;
    skos:altLabel "Siemon III projection" ;
    foaf:image "https://situx.github.io/proj4rdf/projections/QuarticAuthalicProjection.svg"^^xsd:anyURI .

