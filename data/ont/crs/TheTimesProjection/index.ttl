@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:TheTimesProjection a owl:Class ;
    rdfs:label "the times projection"@en ;
    dc:creator "John Muir" ;
    dc:date "1965" ;
    ns1:PROJidentifier "times" ;
    rdfs:subClassOf ns1:CompromiseProjection,
        ns1:PseudoCylindricalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/TheTimesProjection.svg"^^xsd:anyURI .

