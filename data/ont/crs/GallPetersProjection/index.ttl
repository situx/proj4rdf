@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/GallPetersProjection> a owl:Class ;
    rdfs:label "gall-peters projection"@en ;
    dc:creator "James Gall" ;
    dc:date "1855"^^xsd:gYear ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CylindricalProjection>,
        <http://www.opengis.net/ont/crs/EqualAreaProjection> ;
    skos:altLabel "Gall orthographic" ;
    foaf:image "https://situx.github.io/proj4rdf/projections/GallPetersProjection.svg"^^xsd:anyURI .

