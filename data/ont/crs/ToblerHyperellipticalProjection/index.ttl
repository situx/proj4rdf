@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/ToblerHyperellipticalProjection> a owl:Class ;
    rdfs:label "tobler hyperelliptical projection"@en ;
    dc:creator "Waldo Tobler" ;
    dc:date "1973"^^xsd:gYear ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/EqualAreaProjection>,
        <http://www.opengis.net/ont/crs/PseudoCylindricalProjection> .

