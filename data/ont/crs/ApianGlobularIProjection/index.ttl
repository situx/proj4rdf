@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ApianGlobularIProjection a owl:Class ;
    rdfs:label "apian globular I projection"@en ;
    ns1:PROJidentifier "apian" ;
    rdfs:subClassOf ns1:GlobularProjection .

