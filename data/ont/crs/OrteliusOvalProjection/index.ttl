@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:OrteliusOvalProjection a owl:Class ;
    rdfs:label "ortelius oval projection"@en ;
    dc:creator "Abraham Ortelius" ;
    dc:date "1570"^^xsd:gYear ;
    ns1:PROJidentifier "ortel" ;
    rdfs:subClassOf ns1:CompromiseProjection,
        ns1:OvalProjection,
        ns1:PseudoCylindricalProjection .

