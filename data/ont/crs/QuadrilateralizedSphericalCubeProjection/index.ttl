@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:QuadrilateralizedSphericalCubeProjection a owl:Class ;
    rdfs:label "quadrilateralized spherical cube projection"@en ;
    ns1:PROJidentifier "qsc" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PolyhedralProjection .

