@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:GinzburgVIIIProjection a owl:Class ;
    rdfs:label "Ginzburg VIII projection"@en ;
    dc:creator "G.A. Ginzburg" ;
    dc:date "1944"^^xsd:gYear ;
    ns1:PROJidentifier "gins8"^^xsd:anyURI ;
    rdfs:subClassOf ns1:PseudoCylindricalProjection ;
    skos:altLabel "TsNIIGAiK 1944 Pseudocylindrical" .

