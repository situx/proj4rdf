@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LambertAzimuthalEqualArea a owl:Class ;
    rdfs:label "lambert azimuthal equal area projection"@en ;
    ns1:PROJidentifier "laea" ;
    rdfs:subClassOf ns1:AzimuthalProjection,
        ns1:EqualAreaProjection .

