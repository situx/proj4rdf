@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix ns2: <https://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:LeeProjection a owl:Class ;
    rdfs:label "lee projection"@en ;
    ns1:PROJidentifier "lee_os" ;
    rdfs:subClassOf ns1:ConformalProjection,
        ns1:PolyhedralProjection ;
    ns2:image "https://situx.github.io/proj4rdf/projections/LeeProjection.svg"^^xsd:anyURI .

