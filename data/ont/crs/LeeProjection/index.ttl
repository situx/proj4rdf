@prefix ns1: <https://xmlns.com/foaf/0.1/> .
@prefix ns2: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns2:LeeProjection a owl:Class ;
    rdfs:label "lee projection"@en ;
    ns2:PROJidentifier "lee_os" ;
    rdfs:subClassOf ns2:ConformalProjection,
        ns2:PolyhedralProjection ;
    ns1:image "https://situx.github.io/proj4rdf/projections/LeeProjection.svg"^^xsd:anyURI .

