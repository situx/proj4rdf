@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/BottomleyProjection> a owl:Class ;
    rdfs:label "bottomley projection"@en ;
    dc:creator "Henry Bottomley" ;
    dc:date "2003"^^xsd:gYear ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/EqualAreaProjection>,
        <http://www.opengis.net/ont/crs/PseudoConicalProjection> ;
    foaf:image "https://situx.github.io/proj4rdf/projections/BottomleyProjection.svg"^^xsd:anyURI .

