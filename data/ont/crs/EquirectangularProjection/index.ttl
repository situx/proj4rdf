@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/EquirectangularProjection> a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "equirectangular projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CylindricalProjection>,
        <http://www.opengis.net/ont/crs/EquidistantProjection> ;
    foaf:image "https://situx.github.io/proj4rdf/projections/EquirectangularProjection.svg"^^xsd:anyURI .

