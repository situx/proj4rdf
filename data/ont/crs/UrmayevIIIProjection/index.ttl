@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/UrmayevIIIProjection> a owl:Class ;
    rdfs:label "Urmayev III projection"@en ;
    dc:creator "N.A. Urmayev" ;
    dc:date "1947" ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CompromiseProjection>,
        <http://www.opengis.net/ont/crs/CylindricalProjection> ;
    skos:definition "Cylindric projection with an appearance similar to the Mercator, but shows the poles"@en .

