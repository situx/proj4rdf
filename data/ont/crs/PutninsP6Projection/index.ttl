@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:PutninsP6Projection a owl:Class ;
    rdfs:label "Putnins P6 projection" ;
    dc:creator "Reinholds V. Putnins" ;
    dc:date 1934 ;
    ns1:PROJidentifier "putp6" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection .

