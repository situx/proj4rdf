@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:WagnerIXProjection a owl:Class ;
    rdfs:label "wagner IX projection"@en ;
    ns1:PROJidentifier "wag9" ;
    rdfs:subClassOf ns1:PoleLineProjection,
        ns1:PolyconicProjection .

