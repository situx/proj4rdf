@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CentralConicProjection a owl:Class ;
    rdfs:label "central conic projection" ;
    ns1:PROJidentifier "ccon" ;
    rdfs:subClassOf ns1:ConicalProjection .

