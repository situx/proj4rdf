@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/PetermannStarProjection> a owl:Class ;
    rdfs:label "Petermann Star projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CompromiseProjection> ;
    skos:definition "Pole-centered fusion: joins the Azimuthal Equidistant in central hemisphere to eight lobes with straight edges at 0°N" .

