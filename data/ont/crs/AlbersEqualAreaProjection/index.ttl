@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AlbersEqualAreaProjection a owl:Class ;
    rdfs:label "albers equal-area projection"@en ;
    dc:creator "Heinrich C. Albers" ;
    dc:date "1805" ;
    ns1:PROJidentifier "aea" ;
    rdfs:subClassOf ns1:ConicalProjection,
        ns1:EqualAreaProjection ;
    skos:definition "a conic, equal area map projection that uses two standard parallels"@en ;
    foaf:image "https://situx.github.io/proj4rdf/projections/AlbersEqualAreaProjection.svg"^^xsd:anyURI .

