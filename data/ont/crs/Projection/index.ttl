@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/Projection> a owl:Class ;
    rdfs:label "projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/Conversion> ;
    skos:definition "coordinate conversion from an ellipsoidal coordinate system to a plane"@en .

