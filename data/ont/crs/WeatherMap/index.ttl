@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ns1:WeatherMap a owl:Class ;
    rdfs:label "weather map"@en ;
    ns1:uses ns1:ConformalProjection ;
    rdfs:subClassOf ns1:ThematicMap ;
    skos:definition "A map for showing the local direction in which weather systems are moving."@en .

