@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Eckert3Projection a owl:Class ;
    rdfs:label "Eckert III projection"@en ;
    dc:creator "Max Eckert-Greifendorff" ;
    dc:date "1906"^^xsd:gYear ;
    ns1:PROJidentifier "eck3" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/Eckert3Projection.svg"^^xsd:anyURI .

