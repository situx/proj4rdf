@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HatanoAsymmetricalEqualAreaProjection a owl:Class ;
    rdfs:label "hatano asymmetrical equal-area projection"@en ;
    dc:creator "Masataka Hatano" ;
    dc:date "1972" ;
    ns1:PROJidentifier "hatano" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection .

