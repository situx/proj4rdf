@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/LagrangeProjection> a owl:Class ;
    rdfs:label "lagrange projection"@en ;
    dc:creator "Johann Heinrich Lambert" ;
    dc:date "1772"^^xsd:gYear ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/ConformalProjection>,
        <http://www.opengis.net/ont/crs/PolyconicProjection> ;
    foaf:image "https://situx.github.io/proj4rdf/projections/LagrangeProjection.svg"^^xsd:anyURI .

