<http://www.opengis.net/ont/crs/areaofuse/EPSG_Arctic_LCC_zone_6-16_area_of_use> a ns1:AreaOfUse,
        <http://www.w3.org/ns/ldp#Resource>,
        <https://www.iana.org/assignments/media-types/text/turtle#Resource> ;
    rdfs:label "Arctic - between 71°10'N and 66°10'N, approximately 156°W to approximately 138°W. May be extended westwards within the latitude limits."@en ;
