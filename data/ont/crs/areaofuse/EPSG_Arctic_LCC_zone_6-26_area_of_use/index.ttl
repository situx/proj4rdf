<http://www.opengis.net/ont/crs/areaofuse/EPSG_Arctic_LCC_zone_6-26_area_of_use> a ns1:AreaOfUse,
        <http://www.w3.org/ns/ldp#Resource>,
        <https://www.iana.org/assignments/media-types/text/turtle#Resource> ;
    rdfs:label "Arctic - between 71°10'N and 66°10'N, approximately 65°W to approximately 47°W. May be extended westwards or eastwards within the latitude limits."@en ;
    void:inDataset <http://www.opengis.net/dataset> ;
    ns1:extent "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON ((-47 66.16, -47 71.17, -65 71.17, -65 66.16, -47 66.16))"^^geo:wktLiteral .

