@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/areaofuse/World_Mercator_area_of_use> a ns1:AreaOfUse ;
    rdfs:label "World between 80°S and 84°N."@en ;
    ns1:extent "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON ((180 -80, 180 84, -180 84, -180 -80, 180 -80))"^^geo:wktLiteral .

