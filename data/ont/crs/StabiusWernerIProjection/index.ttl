@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/StabiusWernerIProjection> a owl:Class ;
    rdfs:label "Stabius-Werner I projection" ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/EqualAreaProjection>,
        <http://www.opengis.net/ont/crs/PolyconicProjection> .

