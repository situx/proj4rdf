@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/satelliteOf> a owl:ObjectProperty ;
    rdfs:label "satellite of"@en ;
    rdfs:domain <http://www.opengis.net/ont/crs/InterstellarBody> ;
    rdfs:range <http://www.opengis.net/ont/crs/InterstellarBody> ;
    skos:definition "Defines an interstellar body as the natural satellite of another interstellar body."@en .

