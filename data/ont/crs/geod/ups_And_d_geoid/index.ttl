@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/ups_And_d_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for ups And d"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/ups_And_d> ;
    ns1:eccentricity 3.16e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/ups_And_d_geoid_smj_axis> .

