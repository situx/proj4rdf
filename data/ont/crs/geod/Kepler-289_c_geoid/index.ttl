@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/Kepler-289_c_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for Kepler-289 c"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/Kepler-289_c> ;
    ns1:eccentricity 1.15e-02 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/Kepler-289_c_geoid_smj_axis> .

