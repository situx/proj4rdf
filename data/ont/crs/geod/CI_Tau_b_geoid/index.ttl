@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/CI_Tau_b_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for CI Tau b"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/CI_Tau_b> ;
    ns1:eccentricity 2.5e-01 .

