    rdfs:label "Geoid for mu Ara d"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/mu_Ara_d> ;
    ns1:eccentricity 6.66e-02 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/mu_Ara_d_geoid_smj_axis> .

