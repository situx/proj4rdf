@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/42_Dra_b_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for 42 Dra b"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/42_Dra_b> ;
    ns1:eccentricity 3.8e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/42_Dra_b_geoid_smj_axis> .

