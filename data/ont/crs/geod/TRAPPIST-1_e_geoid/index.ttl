@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/TRAPPIST-1_e_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for TRAPPIST-1 e"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/TRAPPIST-1_e> ;
    ns1:eccentricity 0e+00 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/TRAPPIST-1_e_geoid_smj_axis> .

