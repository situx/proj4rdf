@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/tau_Gem_b_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for tau Gem b"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/tau_Gem_b> ;
    ns1:eccentricity 3.1e-02 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/tau_Gem_b_geoid_smj_axis> .

