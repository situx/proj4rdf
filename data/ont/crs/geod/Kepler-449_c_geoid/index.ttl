@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/Kepler-449_c_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for Kepler-449 c"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/Kepler-449_c> ;
    ns1:eccentricity 5e-02 .

