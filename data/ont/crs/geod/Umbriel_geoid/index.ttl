@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix ns2: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/geod/Umbriel_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for Umbriel"@en ;
    ns2:hasUnit ns2:day ;
    ns1:isApplicableTo <http://www.opengis.net/ont/crs/isbody/Umbriel> ;
    ns1:orbital_period <http://www.opengis.net/ont/crs/geod/Umbriel_geoid_obperiod> ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/Umbriel_geoid_smj_axis> .

