@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/Kepler-454_c_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for Kepler-454 c"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/Kepler-454_c> ;
    ns1:eccentricity 2.14e-02 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/Kepler-454_c_geoid_smj_axis> .

