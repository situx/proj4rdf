@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/ups_And_e_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for ups And e"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/ups_And_e> ;
    ns1:eccentricity 5.36e-03 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/ups_And_e_geoid_smj_axis> .

