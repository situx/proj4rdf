    rdfs:label "Geoid for 7 CMA c"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/7_CMA_c> ;
    ns1:eccentricity 4.6e-02 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/7_CMA_c_geoid_smj_axis> .

