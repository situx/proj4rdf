@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/WASP-47_b_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for WASP-47 b"@en ;
