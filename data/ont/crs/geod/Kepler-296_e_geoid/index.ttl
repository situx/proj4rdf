@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/Kepler-296_e_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for Kepler-296 e"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/Kepler-296_e> ;
    ns1:eccentricity 3.3e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/Kepler-296_e_geoid_smj_axis> .

