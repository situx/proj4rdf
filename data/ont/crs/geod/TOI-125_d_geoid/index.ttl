@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/TOI-125_d_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for TOI-125 d"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/TOI-125_d> ;
    ns1:eccentricity 1.68e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/TOI-125_d_geoid_smj_axis> .

