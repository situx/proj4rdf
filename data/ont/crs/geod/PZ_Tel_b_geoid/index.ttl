@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/PZ_Tel_b_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for PZ Tel b"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/PZ_Tel_b> ;
    ns1:eccentricity 6.2e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/PZ_Tel_b_geoid_smj_axis> .

