@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/tau_Cet_h_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for tau Cet h"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/tau_Cet_h> ;
    ns1:eccentricity 2.3e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/tau_Cet_h_geoid_smj_axis> .

