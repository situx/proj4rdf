@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:McBrydeThomasFlatPolarQuarticProjection a owl:Class ;
    rdfs:label "Mc Bryde-Thomas Flat-Polar Quartic projection" ;
    ns1:PROJidentifier "mbtfpq" ;
    rdfs:subClassOf ns1:PseudoCylindricalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/McBrydeThomasFlatPolarQuarticProjection.svg"^^xsd:anyURI .

