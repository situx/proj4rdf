@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DenoyerSemiEllipticalProjection a owl:Class ;
    rdfs:label "denoyer semi-elliptical projection"@en ;
    ns1:PROJidentifier "denoy" ;
    rdfs:subClassOf ns1:CompromiseProjection .

