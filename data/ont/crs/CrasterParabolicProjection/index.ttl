@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:CrasterParabolicProjection a owl:Class ;
    rdfs:label "craster parabolic projection"@en ;
    dc:creator "John E. E. Craster" ;
    dc:date "1929"^^xsd:gYear ;
    ns1:PROJidentifier "crast" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/CrasterParabolicProjection.svg"^^xsd:anyURI .

