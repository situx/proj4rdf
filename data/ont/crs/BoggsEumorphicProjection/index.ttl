@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:BoggsEumorphicProjection a owl:Class ;
    rdfs:label "boggs eumorphic projection"@en ;
    dc:creator "Samuel Whittemore Boggs" ;
    dc:date 1929 ;
    ns1:PROJidentifier "boggs" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/BoggsEumorphicProjection.svg"^^xsd:anyURI .

