@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AdamsWorldInASquareIIProjection a owl:Class ;
    rdfs:label "Adams World in a Square II projection" ;
    ns1:PROJidentifier "adams_ws2" ;
