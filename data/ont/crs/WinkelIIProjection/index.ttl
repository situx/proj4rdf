@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ns1:WinkelIIProjection a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "winkel II projection"@en ;
    dc:creator "Oswald Winkel" ;
    dc:date "1921" ;
    ns1:PROJidentifier "wink2" ;
    ns1:isRelatedTo ns1:ApianIIProjection,
        ns1:EquirectangularProjection ;
    rdfs:subClassOf ns1:CompromiseProjection ;
    skos:definition "Arithmetic average of the Equirectangular and Apian II projections. Pseudocylindric, equally spaced parallels, elliptical meridians, pole line" .

