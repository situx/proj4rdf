@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EquidistantCylindricalProjection a owl:Class ;
    rdfs:label "equidistant cylindrical projection"@en ;
    ns1:PROJidentifier "eqc" ;
    rdfs:subClassOf ns1:CylindricalProjection,
        ns1:EquidistantProjection .

