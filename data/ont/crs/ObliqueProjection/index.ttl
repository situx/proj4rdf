@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/ObliqueProjection> a owl:Class ;
    rdfs:label "oblique projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/Projection> ;
    skos:definition "a projection made by parallel lines drawn from every point of a figure and meeting the plane of projection obliquely"@en .

