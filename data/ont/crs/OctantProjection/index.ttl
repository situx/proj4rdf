@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/OctantProjection> a owl:Class ;
    rdfs:label "octant projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CompromiseProjection>,
        <http://www.opengis.net/ont/crs/PolyhedralProjection> .

