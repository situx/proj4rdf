@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/includesSRS> a owl:ObjectProperty ;
    rdfs:label "includes srs"@en ;
    rdfs:domain <http://www.opengis.net/ont/crs/CompoundCRS> ;
    rdfs:range <http://www.opengis.net/ont/crs/CRS> ;
    skos:definition "Indicates spatial reference systems used by a compound reference system"@en .

