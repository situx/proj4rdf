@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/ThematicMap> a owl:Class ;
    rdfs:label "thematic map"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/SRSApplication> ;
    skos:definition "A map used to highlight a specific phenomenon"@en .

