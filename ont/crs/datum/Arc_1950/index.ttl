@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Arc_1950> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Arc 1950"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/Clarke1880ARC> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:Geodesy,
        ns1:TopographicMap .

