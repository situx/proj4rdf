@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Vanua_Levu_1915> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Vanua Levu 1915"@en ;
    ns1:ellipse "Clarke 1880 (international foot)" ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:Geodesy,
        ns1:TopographicMap .

