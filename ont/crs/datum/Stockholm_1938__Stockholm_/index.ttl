@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Stockholm_1938__Stockholm_> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Stockholm 1938 (Stockholm)"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/Bessel1841> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Stockholm> ;
    ns1:usage ns1:CadastreMap,
        ns1:EngineeringSurvey,
        ns1:Geodesy,
        ns1:TopographicMap .

