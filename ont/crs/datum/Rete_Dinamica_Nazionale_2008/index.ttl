@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Rete_Dinamica_Nazionale_2008> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Rete Dinamica Nazionale 2008"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/GRS1980> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:Geodesy,
        ns1:TopographicMap .

