@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/datum/Geocentric_datum_of_Korea> a ns1:GeodeticReferenceFrame ;
    rdfs:label "Datum: Geocentric datum of Korea"@en ;
    ns1:ellipsoid <http://www.opengis.net/ont/crs/geod/GRS1980> ;
    ns1:primeMeridian <http://www.opengis.net/ont/crs/primeMeridian/Greenwich> ;
    ns1:usage ns1:Geodesy .

