@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NellProjection a owl:Class ;
    rdfs:label "nell projection"@en ;
    dc:creator "Adam Nell" ;
    dc:date "1890" ;
    ns1:PROJidentifier "nell" ;
    rdfs:subClassOf ns1:PseudoCylindricalProjection .

