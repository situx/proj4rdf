@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/isInverseProjectionOf> a owl:ObjectProperty ;
    rdfs:label "is inverse projection of"@en ;
    skos:definition "Defines an inverse projection to the projection identified as the subject"@en .

