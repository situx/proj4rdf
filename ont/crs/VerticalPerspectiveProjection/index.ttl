@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/VerticalPerspectiveProjection> a owl:Class ;
    rdfs:label "vertical perspective projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/AzimuthalProjection>,
        <http://www.opengis.net/ont/crs/PerspectiveProjection> .

