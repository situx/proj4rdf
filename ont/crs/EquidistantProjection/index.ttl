@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/EquidistantProjection> a owl:Class ;
    rdfs:label "equidistant projection"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/Projection> ;
    skos:definition "Projection in which all points on the map exhibit proportionally correct distances from the center point"@en .

