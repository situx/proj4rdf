@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://www.opengis.net/ont/crs/GridCS> a owl:Class ;
    rdfs:label "grid coordinate system"@en ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/CoordinateSystem> ;
    skos:definition "A grid coordinate system describes areas with a grid"@en .

