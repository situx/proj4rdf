@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ColombiaUrbanProjection a owl:Class ;
    rdfs:label "colombia urban projection"@en ;
    ns1:PROJidentifier "col_urban" ;
    rdfs:subClassOf ns1:Projection .

