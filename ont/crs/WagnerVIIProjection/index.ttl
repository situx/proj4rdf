@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:WagnerVIIProjection a owl:Class ;
    rdfs:label "wagner VII projection"@en ;
    dc:creator "Karlheinz Wagner" ;
    dc:date "1941" ;
    ns1:PROJidentifier "wag7" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PolyconicProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/WagnerVIIProjection.svg"^^xsd:anyURI .

