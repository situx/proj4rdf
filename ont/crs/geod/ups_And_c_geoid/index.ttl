@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/ups_And_c_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for ups And c"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/ups_And_c> ;
    ns1:eccentricity 2.445e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/ups_And_c_geoid_smj_axis> .

