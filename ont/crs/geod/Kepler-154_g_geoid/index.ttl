@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/Kepler-154_g_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for Kepler-154 g"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/Kepler-154_g> ;
    ns1:eccentricity 1.5e-01 .

