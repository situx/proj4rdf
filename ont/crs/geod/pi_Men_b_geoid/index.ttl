@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/geod/pi_Men_b_geoid> a ns1:Sphere ;
    rdfs:label "Geoid for pi Men b"@en ;
    ns1:approximates <http://www.opengis.net/ont/crs/isbody/pi_Men_b> ;
    ns1:eccentricity 6.45e-01 ;
    ns1:semiMajorAxis <http://www.opengis.net/ont/crs/geod/pi_Men_b_geoid_smj_axis> .

