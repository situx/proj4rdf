@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PeirceQuincuncialProjection a owl:Class ;
    rdfs:label "peirce quincuncial projection"@en ;
    dc:creator "Charles Sanders Peirce" ;
    dc:date "1879" ;
    ns1:PROJidentifier "peirce_q" ;
    rdfs:subClassOf ns1:ConformalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/PericeQuincuncialProjection.svg" .

