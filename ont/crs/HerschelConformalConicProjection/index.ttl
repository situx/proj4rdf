@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.opengis.net/ont/crs/HerschelConformalConicProjection> a owl:Class ;
    rdfs:label "herschel conformal conic projection"@en ;
    dc:creator "John F.W. Herschel" ;
    dc:date "1859" ;
    rdfs:subClassOf <http://www.opengis.net/ont/crs/ConformalProjection>,
        <http://www.opengis.net/ont/crs/ConicalProjection> .

