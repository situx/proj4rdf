@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ns1:HEALPixProjection a owl:Class ;
    rdfs:label "HEALPix projection"@en ;
    ns1:PROJidentifier "healpix" ;
    rdfs:subClassOf ns1:EqualAreaProjection,
        ns1:PseudoCylindricalProjection ;
    skos:definition "Fusion; joins the Cylindrical Equal-Area and Collignon at ±41°71'. Interrupted for all but the H=1 case"@en .

