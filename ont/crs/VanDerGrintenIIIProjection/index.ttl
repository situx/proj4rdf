@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:VanDerGrintenIIIProjection a owl:Class ;
    rdfs:label "van der grinten III projection"@en ;
    dc:creator "Alois Bludeau" ;
    dc:date 1912 ;
    ns1:PROJidentifier "vandg3" ;
    rdfs:subClassOf ns1:CompromiseProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/VanDerGrintenIIIProjection.svg"^^xsd:anyURI .

