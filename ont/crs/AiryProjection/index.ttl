@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AiryProjection a owl:Class ;
    rdfs:label "airy projection"@en ;
    dc:creator "George Biddell Airy" ;
    dc:date "1861" ;
    ns1:PROJidentifier "airy" ;
    rdfs:subClassOf ns1:AzimuthalProjection,
        ns1:MinimumErrorProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/AiryProjection.svg"^^xsd:anyURI .

