@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/isbody/Hydra> a ns1:Moon ;
    rdfs:label "Hydra"@en ;
    ns1:planet_status ns1:Confirmed ;
    ns1:radius 2.75e+01 ;
    ns1:satelliteOf <http://www.opengis.net/ont/crs/isbody/Pluto> .

