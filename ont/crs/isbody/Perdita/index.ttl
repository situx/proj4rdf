@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.opengis.net/ont/crs/isbody/Perdita> a ns1:Moon ;
    rdfs:label "Perdita"@en ;
    ns1:planet_status ns1:Confirmed ;
