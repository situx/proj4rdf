@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <http://www.opengis.net/ont/crs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AitoffProjection a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "aitoff projection"@en ;
    dc:creator "David Aitoff" ;
    dc:date "1889" ;
    ns1:PROJidentifier "aitoff" ;
    rdfs:subClassOf ns1:CompromiseProjection,
        ns1:PseudoAzimuthalProjection ;
    foaf:image "https://situx.github.io/proj4rdf/projections/AitoffProjection.svg"^^xsd:anyURI .

